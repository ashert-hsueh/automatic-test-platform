```
autotest-platform/
├── backend/
│   ├── alembic/               # 数据库迁移脚本
│   ├── app/
│   │   ├── api/               # FastAPI 路由层
│   │   │   ├── v1/
│   │   │   │   ├── auth.py
│   │   │   │   ├── projects.py
│   │   │   │   ├── testcases.py
│   │   │   │   ├── reports.py
│   │   │   │   └── tasks.py
